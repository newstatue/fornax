{
  "openapi": "3.1.0",
  "info": {
    "title": "fornax",
    "description": "",
    "contact": {
      "name": "Evorsio"
    },
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787",
      "description": "Local"
    },
    {
      "url": "https://fornax.com",
      "description": "Production"
    }
  ],
  "paths": {
    "/api/": {
      "get": {
        "tags": [
          "General"
        ],
        "operationId": "root",
        "responses": {
          "200": {
            "description": "服务正常"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResp_LoginResp"
                }
              }
            }
          },
          "400": {
            "description": "邮箱或验证码格式错误"
          },
          "401": {
            "description": "验证码错误或已过期"
          },
          "403": {
            "description": "用户已被停用"
          },
          "500": {
            "description": "服务器内部错误"
          }
        }
      }
    },
    "/api/auth/send-code": {
      "post": {
        "tags": [
          "Auth"
        ],
        "operationId": "send_code",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "验证码发送成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResp_SendCodeResp"
                }
              }
            }
          },
          "400": {
            "description": "邮箱格式错误"
          },
          "429": {
            "description": "验证码发送过于频繁"
          },
          "500": {
            "description": "服务器内部错误"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResp_LoginResp": {
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "data": {
            "type": "object",
            "required": [
              "token"
            ],
            "properties": {
              "token": {
                "type": "string"
              }
            }
          },
          "errors": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "msg": {
            "type": "string"
          }
        }
      },
      "ApiResp_SendCodeResp": {
        "type": "object",
        "required": [
          "code",
          "msg"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "data": {
            "type": "object",
            "required": [
              "cd"
            ],
            "properties": {
              "cd": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              }
            }
          },
          "errors": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "msg": {
            "type": "string"
          }
        }
      },
      "LoginReq": {
        "type": "object",
        "required": [
          "email",
          "code"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "LoginResp": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "SendCodeReq": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "SendCodeResp": {
        "type": "object",
        "required": [
          "cd"
        ],
        "properties": {
          "cd": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth",
      "description": "认证接口"
    }
  ]
}